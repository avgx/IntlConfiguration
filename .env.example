# Скопируй в `.env` в корне репозитория (файл `.env` в git не коммитится).
# Переменные в окружении процесса перекрывают значения из `.env`.
# INTL_URL — базовый URL web2, например https://host/web2
# INTL_LIVE=1 — включить live-тест `liveConfigurationDecodes` при `swift test`

INTL_URL=
INTL_USER=
INTL_PASSWORD=
INTL_LIVE=

